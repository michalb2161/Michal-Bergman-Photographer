PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/studio_lux_portfolio
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4200
REGISTER_ENABLED=true
UPLOAD_DIR=uploads

# חובה לשליחת מייל אמיתית מטופס "צור קשר" (אחרת ההודעה רק נשמרת במסד)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourstudio.com
MAIL_TO=studio@yourstudio.com

# Default admin created by npm run seed (change after first login)
ADMIN_EMAIL=admin@studio.local
ADMIN_PASSWORD=ChangeMe123!
